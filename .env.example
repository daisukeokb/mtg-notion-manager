# Notion Integration Token (Internal Integration Secret)
# https://www.notion.so/my-integrations で発行し、対象ページ/DBに integration を接続してください。
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MTG統率者DB のデータソースID (collection://の後ろのUUID部分)
NOTION_COMMANDER_DATA_SOURCE_ID=00000000-0000-0000-0000-000000000000

# MTGカードDB のデータソースID (将来のカード連携用、MVPでは未使用)
NOTION_CARD_DATA_SOURCE_ID=00000000-0000-0000-0000-000000000000
